DJANGO_SETTINGS_MODULE=sentai.settings.dev
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_LANGUAGE_CODE=en
DJANGO_TIME_ZONE=Europe/Warsaw
SITE_BASE_URL=http://127.0.0.1:8000

# Use sqlite locally by default. Switch to postgres in production.
DB_ENGINE=sqlite
DB_NAME=sentai
DB_USER=sentai
DB_PASSWORD=sentai
DB_HOST=localhost
DB_PORT=5432
